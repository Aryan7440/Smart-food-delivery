# ----------------------------------------------------------------------
# App
# ----------------------------------------------------------------------
APP_NAME=Smart Food Ordering API
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ----------------------------------------------------------------------
# Model loading
# ----------------------------------------------------------------------
# Relative to the working dir in the container. For HF Spaces (models
# bundled in the repo via git-lfs), keep this as-is. For local Docker
# runs with a volume mount, override to e.g. MODEL_DIR=/models.
MODEL_DIR=app/ml/models

# Master switch for loading the real ML models vs. rule-based fallbacks.
USE_AI_MODELS=true

# ----------------------------------------------------------------------
# HuggingFace Hub — OPTIONAL. Only needed if the DistilBERT review
# classifier directory is not bundled in the Space/image and should be
# snapshotted at startup instead. Leave blank when models are bundled.
# ----------------------------------------------------------------------
HF_REVIEW_REPO=
HF_REVIEW_REVISION=                  # optional: pin to a commit SHA or tag
HF_TOKEN=                            # only needed for private repos
